{
  "name": "@judge-gym/engine-convex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "../../scripts/with_root_env.sh convex dev",
    "predev": "../../scripts/with_root_env.sh convex dev --until-success",
    "codegen": "../../scripts/with_root_env.sh convex codegen",
    "telemetry:check": "../../scripts/with_root_env.sh bun run scripts/check_telemetry.ts",
    "debug:watch": "../../scripts/with_root_env.sh bun run scripts/live_debug.ts watch",
    "debug:stuck": "../../scripts/with_root_env.sh bun run scripts/live_debug.ts stuck",
    "debug:heal": "../../scripts/with_root_env.sh bun run scripts/live_debug.ts heal",
    "debug:tail": "../../scripts/with_root_env.sh bun run scripts/live_debug.ts tail",
    "debug:analyze": "../../scripts/with_root_env.sh bun run scripts/live_debug.ts analyze",
    "debug:matrix": "../../scripts/with_root_env.sh bun run scripts/synthetic_matrix.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:once": "vitest run",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "vitest run --coverage --coverage.reporter=text",
    "test:live": "../../scripts/with_root_env.sh env VITEST_LIVE_TESTS=1 vitest run",
    "test:live:coverage": "../../scripts/with_root_env.sh env VITEST_LIVE_TESTS=1 vitest run --coverage --coverage.reporter=text"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.35",
    "@ai-sdk/google": "^3.0.20",
    "@ai-sdk/openai": "^3.0.24",
    "@ai-sdk/xai": "^3.0.46",
    "@convex-dev/rate-limiter": "^0.2.14",
    "@mendable/firecrawl-js": "^4.12.0",
    "@openrouter/ai-sdk-provider": "^2.1.1",
    "ai": "^6.0.66",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.113",
    "nanoid": "^5.1.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "convex-test": "^0.0.41",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
