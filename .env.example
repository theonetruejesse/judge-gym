CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

OPENAI_API_KEY=
FIRECRAWL_API_KEY=

# Optional provider keys
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# OPENROUTER_API_KEY=
# XAI_API_KEY=

# Optional local Redis URL if you ever run the Temporal worker outside Railway.
# For the normal Railway worker deploy, scripts/deploy_railway_worker.sh defaults
# the worker service to ${{Redis.REDIS_URL}} instead.
# REDIS_URL=
# REDIS_KEY_PREFIX=judge-gym:quota

# Local scripts and Convex use the public Temporal TCP endpoint.
# The Railway-hosted worker service should use the private Railway
# Temporal frontend alias instead. The current official Railway
# template uses temporalserver:7233 by default.
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=default

# Optional Railway worker override for scripts/deploy_railway_worker.sh
# RAILWAY_TEMPORAL_PRIVATE_ADDRESS=temporalserver:7233
# RAILWAY_REDIS_URL_REFERENCE=${{Redis.REDIS_URL}}

# Optional telemetry
# AXIOM_DATASET=judge-gym
# AXIOM_TOKEN=
