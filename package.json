{
  "name": "judge-gym",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.1.27",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=@judge-gym/engine-convex --filter=@judge-gym/lab",
    "build": "turbo build",
    "test": "turbo test",
    "pilot:smoke": "cd apps/engine-convex && bun run pilot:smoke",
    "typecheck": "turbo run typecheck",
    "validate:convex": "(cd apps/engine-convex && npx convex codegen) && bun run typecheck"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  },
  "module": "index.ts"
}
